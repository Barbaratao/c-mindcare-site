---
const currentYear = new Date().getFullYear();

const columns = [
  {
    title: 'Products',
    links: [
      { name: 'C-Mind', href: 'https://pro.c-mindcare.com', external: true },
      { name: 'Lafiya AI', href: '/lafiya' },
      { name: 'All Products', href: '/products' },
    ],
  },
  {
    title: 'Company',
    links: [
      { name: 'About', href: '/about' },
      { name: 'Safety & Responsibility', href: '/safety' },
      { name: 'Contact', href: '/contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { name: 'Privacy Policy', href: '/privacy' },
      { name: 'Terms of Service', href: '/terms' },
    ],
  },
];
---

<footer class="bg-stone-900 text-stone-300">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-5">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/cmind-logo.png" alt="C-Mind logo" class="h-10 w-10 rounded-lg object-contain" />
          <span class="font-display text-lg font-bold tracking-tight text-white">C-Mind</span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-6 text-stone-400">
          Evidence-based, safety-first clinical AI for mental health and primary care — built to augment human care, never replace it.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-white">{col.title}</h3>
          <ul class="mt-4 space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-stone-400 transition hover:text-teal-400"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 border-t border-stone-800 pt-8 sm:flex sm:items-center sm:justify-between">
      <p class="text-xs text-stone-500">
        &copy; {currentYear} C-Mind LLC. All rights reserved.
      </p>
      <p class="mt-2 text-xs font-medium tracking-wide text-stone-500 sm:mt-0">
        Patent Pending (U.S. App. No. 64/016,668)
      </p>
    </div>
  </div>
</footer>
