---
import BaseLayout from "../layouts/BaseLayout.astro";

const reasons = [
  {
    title: 'Clinical Partnerships',
    body: 'Clinics and health systems interested in deploying C-Mind or Lafiya AI.',
  },
  {
    title: 'Research Collaboration',
    body: 'Researchers and institutions exploring studies, validation, or grants.',
  },
  {
    title: 'General Inquiries',
    body: 'Press, careers, or anything else — we read every message.',
  },
];
---

<BaseLayout title="Contact | C-Mind" description="Get in touch with C-Mind for clinical partnerships, research collaboration, or general inquiries.">
  <!-- PAGE HERO -->
  <section class="border-b border-stone-200 bg-stone-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-teal-600">Contact</p>
        <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
          Get in touch
        </h1>
        <p class="mt-6 text-lg leading-8 text-stone-600">
          For general inquiries, collaboration opportunities, or additional information about C-Mind, we'd love to hear from you.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Email card -->
      <div class="mx-auto max-w-xl">
        <a href="mailto:info@c-mindcare.com" class="group block w-full rounded-3xl bg-stone-50 p-10 text-center ring-1 ring-stone-900/5 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-teal-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="h-6 w-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h2 class="mt-5 text-lg font-semibold text-stone-900 group-hover:text-teal-900">Email Us</h2>
          <p class="mt-2 text-base font-medium text-teal-700 group-hover:text-teal-800">info@c-mindcare.com</p>
        </a>
      </div>

      <!-- Reasons -->
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-3 lg:max-w-4xl">
        {reasons.map((r) => (
          <div class="rounded-2xl border border-stone-200 p-6 text-center">
            <h3 class="text-sm font-semibold text-stone-900">{r.title}</h3>
            <p class="mt-2 text-sm leading-6 text-stone-600">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
