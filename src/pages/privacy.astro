---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy | C-Mind" description="Privacy policy for the C-Mind website.">
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-teal-600">Legal</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-stone-900">Privacy Policy</h1>
      <p class="mt-2 text-sm text-stone-500">Last updated: June 10, 2026</p>

      <div class="mt-10 space-y-8 text-base leading-7 text-stone-600">
        <p>
          This Privacy Policy describes how C-Mind LLC ("C-Mind," "we," "us") handles information collected through this website, c-mindcare.com. It does not govern our clinical products; those are covered by separate agreements and privacy notices provided to participating organizations and their patients.
        </p>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Information we collect</h2>
          <p class="mt-3">
            This website does not require an account and does not ask you to submit personal or health information. If you contact us by email, we receive the information you choose to include in your message, and we use it only to respond to your inquiry.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Cookies and analytics</h2>
          <p class="mt-3">
            This website is served through Cloudflare, which may set strictly necessary cookies for security and performance purposes. We do not use advertising trackers on this site.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Health information</h2>
          <p class="mt-3">
            Do not send protected health information through this website or by email. Within our clinical products, protected health information is handled on HIPAA-eligible infrastructure under Business Associate Agreements with participating organizations.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Sharing</h2>
          <p class="mt-3">
            We do not sell personal information. We do not share information collected through this website with third parties except as required to operate the site or comply with law.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Contact</h2>
          <p class="mt-3">
            Questions about this policy can be sent to <a href="mailto:info@c-mindcare.com" class="font-medium text-teal-700 hover:text-teal-800">info@c-mindcare.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
