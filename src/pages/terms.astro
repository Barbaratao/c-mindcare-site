---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Service | C-Mind" description="Terms of service for the C-Mind website.">
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-teal-600">Legal</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-stone-900">Terms of Service</h1>
      <p class="mt-2 text-sm text-stone-500">Last updated: June 10, 2026</p>

      <div class="mt-10 space-y-8 text-base leading-7 text-stone-600">
        <p>
          These terms govern your use of this website, c-mindcare.com, operated by C-Mind LLC ("C-Mind," "we," "us"). Use of our clinical products is governed by separate agreements with participating organizations.
        </p>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Informational purposes only</h2>
          <p class="mt-3">
            Content on this website is provided for general informational purposes. It is not medical advice and is not a substitute for professional medical care, diagnosis, or treatment. If you are experiencing a medical or mental health emergency, call or text 988 (United States), dial your local emergency number, or go to the nearest emergency room.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-stone-900">Intellectual property</h2>
