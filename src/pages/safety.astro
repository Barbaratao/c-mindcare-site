---
import BaseLayout from "../layouts/BaseLayout.astro";

const safeguards = [
  {
    title: 'Crisis-Aware by Design',
    body: 'Deterministic safety systems continuously monitor for crisis and elevated-risk situations. When risk is detected, the platform surfaces appropriate support resources and escalates to the care team in real time — this behavior is never left to chance.',
    icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z',
  },
  {
    title: 'Human Oversight, Always',
    body: 'Clinicians remain responsible for clinical decisions. Providers receive alerts, review structured session summaries, and direct the plan of care. C-Mind extends their reach between visits — it never acts as an autonomous clinician.',
    icon: 'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z',
  },
  {
    title: 'Clear Clinical Boundaries',
    body: 'C-Mind is not a replacement for professional mental health care, diagnosis, or treatment. The platform states its role plainly to every user and is engineered to stay within its supportive, between-session scope.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z',
  },
  {
    title: 'Evidence-Based Content',
    body: 'Clinical guidance comes from a curated knowledge graph built on established therapeutic frameworks and treatment guidelines, validated systematically — not from unconstrained text generation.',
    icon: 'M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25',
  },
  {
    title: 'Data Protection',
    body: 'Protected health information is encrypted in transit and at rest and processed on HIPAA-eligible infrastructure under a Business Associate Agreement. Access follows the minimum-necessary principle.',
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z',
  },
  {
    title: 'Continuous Validation',
    body: 'Safety behavior, clinical content, and escalation pathways are exercised against systematic test suites and audited regularly. We treat safety as an engineering discipline, not a policy document.',
    icon: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  },
];
---

<BaseLayout title="Safety & Responsibility | C-Mind" description="Safety and responsible use are foundational to C-Mind: crisis-aware design, human oversight, clear boundaries, and data protection.">
  <!-- PAGE HERO -->
  <section class="border-b border-stone-200 bg-stone-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-teal-600">Core Values</p>
        <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
          Safety &amp; Responsibility
        </h1>
        <p class="mt-6 text-lg leading-8 text-stone-600">
          Safety and responsible use are foundational to the design of C-Mind — engineered into the platform, validated continuously, and never optional.
        </p>
      </div>
    </div>
  </section>

  <!-- SAFEGUARDS GRID -->
  <section class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
        {safeguards.map((s) => (
          <div class="rounded-2xl bg-stone-50 p-8 ring-1 ring-stone-900/5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
              </svg>
            </div>
            <h2 class="mt-5 text-base font-semibold text-stone-900">{s.title}</h2>
            <p class="mt-3 text-sm leading-6 text-stone-600">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CRISIS RESOURCES -->
  <section class="bg-stone-50 py-16">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-teal-200 bg-teal-50 p-8 text-center">
        <h2 class="text-base font-semibold text-teal-900">If you or someone you know is in crisis</h2>
        <p class="mt-2 text-sm leading-6 text-teal-800">
          Call or text <strong>988</strong> (Suicide &amp; Crisis Lifeline, United States), dial your local emergency number, or go to the nearest emergency room. C-Mind products are not emergency services.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
